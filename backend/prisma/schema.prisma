generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Customer {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  phone       String
  address     String?
  notes       String?
  preferences String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]

  @@map("customers")
}

model Order {
  id          String        @id @default(uuid())
  orderNumber String        @unique @default(cuid())
  customerId  String
  customer    Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status      String        @default("PENDING")
  priority    String        @default("MEDIUM")
  totalAmount Float
  description String?
  dueDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  items       OrderItem[]
  production  Production[]

  @@index([customerId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  
  // Atributos de Lavanderia Profissional (Referenciando Tabelas)
  serviceType String? // Lavar e Passar, Apenas Passar, Limpeza a Seco, etc.
  brandId     String?
  brand       Brand?  @relation(fields: [brandId], references: [id])
  color       String? // Cor predominante
  fabric      String? // Tipo de tecido (ex: Algodão, Seda, Linho)
  dirtLevel   String? // Nível de sujidade (Leve, Médio, Pesado)
  damageNotes String? // Avarias/Manchas pré-existentes (Check-in)
  notes       String? // Observações específicas da peça

  @@index([orderId])
  @@index([productId])
  @@index([brandId])
  @@map("order_items")
}

model Brand {
  id          String      @id @default(uuid())
  name        String      @unique
  description String?
  logoUrl     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]

  @@map("brands")
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@map("categories")
}

model Product {
  id                String      @id @default(uuid())
  name              String      // Nome da peça (ex: Camisa Social)
  description       String?
  sku               String      @unique
  
  // Precificação por Tipo de Serviço
  price             Float       // Preço base/padrão
  washAndIronPrice  Float?      // Preço Lavar e Passar
  ironOnlyPrice     Float?      // Preço Apenas Passar
  dryCleanPrice     Float?      // Preço Limpeza a Seco
  
  // Gestão de Insumos (opcional para peças, obrigatório para produtos de venda/uso)
  stock             Int         @default(0)
  minStock          Int         @default(0)
  
  categoryId        String?
  category          Category?   @relation(fields: [categoryId], references: [id])
  unit              String?     @default("pç") // pç, un, kg, m2
  
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  orderItems        OrderItem[]

  @@index([categoryId])
  @@map("products")
}

model Production {
  id         String           @id @default(uuid())
  orderId    String
  order      Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status     String           @default("PENDING")
  assignedTo String?
  employee   Employee?        @relation(fields: [assignedTo], references: [id])
  startDate  DateTime?
  endDate    DateTime?
  notes      String?
  stage      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([orderId])
  @@index([assignedTo])
  @@index([status])
  @@map("production")
}

model Employee {
  id          String         @id @default(uuid())
  name        String
  email       String         @unique
  phone       String?
  role        String         @default("STAFF")
  status      String         @default("ACTIVE")
  department  String?
  hireDate    DateTime       @default(now())
  salary      Float?
  passwordHash String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  production  Production[]
  timeRecords TimeRecord[]

  @@map("employees")
}

model TimeRecord {
  id         String         @id @default(uuid())
  employeeId String
  employee   Employee       @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type       String
  timestamp  DateTime       @default(now())
  notes      String?

  @@index([employeeId])
  @@index([timestamp])
  @@map("time_records")
}

model Transaction {
  id          String          @id @default(uuid())
  type        String
  category    String
  amount      Float
  description String?
  date        DateTime        @default(now())
  paymentMethod String?
  orderId     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([type])
  @@index([date])
  @@map("transactions")
}

model Settings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}
